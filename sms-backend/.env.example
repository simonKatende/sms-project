# ============================================================
# SMS Backend — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://sms_user:yourpassword@localhost:5432/sms_db

# ── JWT Auth ─────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=a_long_random_secret_string_at_least_64_chars_change_before_production
JWT_REFRESH_SECRET=another_long_random_secret_string_at_least_64_chars_change_before_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── EgoSMS (Pahappa comms-sdk) ───────────────────────────────
EGOSMS_USERNAME=your_egosms_username
EGOSMS_PASSWORD=your_egosms_password
EGOSMS_SENDER_ID=SchoolName

# ── SchoolPay ────────────────────────────────────────────────
SCHOOLPAY_API_URL=https://sandbox.schoolpay.co.ug/api
SCHOOLPAY_API_KEY=your_sandbox_key

# ── File Storage ─────────────────────────────────────────────
STORAGE_PATH=./storage

# ── Scheduler (cron expressions) ─────────────────────────────
# EgoSMS delivery status poll — every 5 minutes
EGOSMS_POLL_CRON=*/5 * * * *
# SchoolPay sync — every 30 minutes, school hours Mon–Fri
SCHOOLPAY_SYNC_CRON=*/30 7-17 * * 1-5
